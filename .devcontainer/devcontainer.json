{
  "name": "cipherShot",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "forwardPorts": [3000, 3001],
  "portsAttributes": {
    "3000": {
      "label": "Web App",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Web App 2",
      "onAutoForward": "notify"
    }
  },
  "appPort": ["9000:3000", "9001:3001"],
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/projects/-Users-federicofilippello-Projects-games-cipherShot,target=/home/node/.claude/projects/-workspaces-cipherShot,type=bind,consistency=cached"
  ],
  "runArgs": ["--memory=6g", "--memory-swap=6g"]
}
