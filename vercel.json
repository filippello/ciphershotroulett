{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_SOLANA_RPC_URL": "@solana-rpc-url",
    "VITE_PER_ENDPOINT": "@per-endpoint",
    "VITE_CIPHERSHOT_PROGRAM_ID": "@ciphershot-program-id"
  }
}
